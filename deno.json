{
  "fmt": {
    "semiColons": false,
    "singleQuote": true,
    "exclude": ["dist"]
  },
  "lint": {
    "rules": {
      "exclude": ["jsx-key"]
    }
  },
  "workspace": ["./src/api", "./src/bf", "./src/site"],
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "jsx",
    "jsxFragmentFactory": "Fragment"
  },
  "tasks": {
    "get-tsg-cws": {
      "description": "Get The Story Graph content warning data",
      "command": "deno run -A ./scripts/get-tsg-cws.ts"
    },
    "save-suggestions": {
      "description": "Save suggestions to disk",
      "command": "deno run -A --env-file ./scripts/save-suggestions.ts"
    },
    "save-tally": {
      "description": "Save a tally to disk",
      "command": "deno run -A --env-file ./scripts/save-tally.ts"
    }
  }
}
